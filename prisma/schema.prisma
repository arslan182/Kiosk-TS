/// https://www.prisma.io/docs/orm/reference/preview-features/client-preview-features#currently-active-preview-features
generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema", "nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["kiosk"]
}

/// https://www.prisma.io/docs/orm/reference/prisma-schema-reference#datasource
model Betreiber {
  id         Int         @id @default(autoincrement())
  vorname    String
  nachname   String
  geschlecht Geschlecht?
  kioskId    Int         @map("kiosk_id")
  kiosk      Kiosk       @relation(fields: [kioskId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([kioskId])
  @@index([nachname])
  @@index([vorname])
  @@map("betreiber")
  @@schema("kiosk")
}

model Kiosk {
  id           Int         @id @default(autoincrement())
  version      Int         @default(0)
  name         String
  email        String      @unique
  istGeoeffnet Boolean     @default(true) @map("ist_geoeffnet")
  homepage     String?
  username     String
  erzeugt      DateTime    @db.Timestamp(6)
  aktualisiert DateTime    @db.Timestamp(6)
  betreiber    Betreiber[]
  produkt      Produkt[]

  @@index([name])
  @@map("kiosk")
  @@schema("kiosk")
}

model Produkt {
  id       Int     @id @default(autoincrement())
  name     String
  preis    Decimal @db.Decimal(10, 2)
  waehrung String
  kioskId  Int     @map("kiosk_id")
  kiosk    Kiosk   @relation(fields: [kioskId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([kioskId])
  @@map("produkt")
  @@schema("kiosk")
}

enum Geschlecht {
  MAENNLICH
  WEIBLICH
  DIVERS

  @@map("geschlecht")
  @@schema("kiosk")
}
